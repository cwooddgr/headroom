<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>co.dgrlabs.headroom.collector</string>
	<key>BundleProgram</key>
	<string>Contents/MacOS/HeadroomCollector</string>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>StandardOutPath</key>
	<string>~/Library/Application Support/Headroom/collector.log</string>
	<key>StandardErrorPath</key>
	<string>~/Library/Application Support/Headroom/collector.log</string>
</dict>
</plist>
